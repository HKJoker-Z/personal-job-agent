APP_ENV=production
DATABASE_URL=
REDIS_URL=redis://redis:6379/0
POSTGRES_DB=personal_job_agent
POSTGRES_BOOTSTRAP_USER=pja_bootstrap
POSTGRES_BOOTSTRAP_PASSWORD=
POSTGRES_MIGRATION_USER=pja_migrator
POSTGRES_MIGRATION_PASSWORD=
POSTGRES_APP_USER=pja_app
POSTGRES_APP_PASSWORD=
SESSION_COOKIE_NAME=pja_session
SESSION_COOKIE_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=24
REMEMBER_ME_SESSION_TTL_DAYS=30
SESSION_TOUCH_INTERVAL_SECONDS=60
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_TRUSTED_ORIGINS=https://your.example.com
AUTH_FINGERPRINT_KEY=
FILE_STORAGE_ROOT=/app/runtime/files
MAX_STORED_FILE_SIZE_MB=10
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10
AGENT_WORKER_CONCURRENCY=4
AGENT_WORKER_HEARTBEAT_SECONDS=15
AGENT_WORKER_STALE_SECONDS=90
AGENT_WORKER_STEP_LEASE_SECONDS=900
AGENT_MAX_AUTO_RETRIES=3
AGENT_USER_CONCURRENCY_LIMIT=2
AGENT_DAILY_TOKEN_LIMIT=100000
AGENT_DAILY_COST_LIMIT_USD=5
AGENT_RUN_TOKEN_LIMIT=30000
AGENT_STEP_TOKEN_LIMIT=8000
AGENT_RUN_COST_LIMIT_USD=2
AGENT_HIGH_COST_APPROVAL_USD=0.50
AGENT_MODEL_MAX_OUTPUT_TOKENS=1200
MODEL_INPUT_COST_PER_MILLION_USD=
MODEL_OUTPUT_COST_PER_MILLION_USD=
SSE_MAX_CONNECTIONS_PER_USER=3
SSE_HEARTBEAT_SECONDS=15
REQUEST_MAX_BODY_MB=12
MINIMUM_FREE_DISK_MB=1024
READINESS_REQUIRE_REDIS=true
READINESS_REQUIRE_WORKER=true
PROJECT_KNOWLEDGE_PATH=/app/project-knowledge/PROJECT_KNOWLEDGE.md
PROJECT_KNOWLEDGE_SEED_PATH=/app/seed/PROJECT_KNOWLEDGE.md
DEEPSEEK_API_KEY=
ALLOWED_ORIGINS=
TRUSTED_HOSTS=your.example.com
MAX_UPLOAD_SIZE_MB=10
ANALYSIS_RESUME_MAX_CHARS=100000
ANALYSIS_JOB_DESCRIPTION_MAX_CHARS=60000
REQUEST_TIMEOUT_SECONDS=60
ENABLE_API_DOCS=false
LOG_LEVEL=INFO
MONITORING_ADMIN_TOKEN=
MONITORING_ALLOW_REMOTE_ADMIN=false
MOCK_PROVIDER_ENABLED=false
PUBLIC_HTTP_PORT=8080
APP_DATA_DIR=./runtime/data
FILE_STORAGE_DIR=./runtime/files
PROJECT_KNOWLEDGE_DIR=./runtime/project-knowledge
BACKUP_DIR=./runtime/backups
RELEASE_VERSION=2.0.3
BACKEND_IMAGE=ghcr.io/hkjoker-z/personal-job-agent-backend@sha256:replace_with_64_hex_digest
FRONTEND_IMAGE=ghcr.io/hkjoker-z/personal-job-agent-frontend@sha256:replace_with_64_hex_digest
APPLICATION_NETWORK_NAME=job-agent_application
POSTGRES_VOLUME_NAME=personal-job-agent-v2-postgres-data
REDIS_VOLUME_NAME=personal-job-agent-v2-redis-data
